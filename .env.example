# ---- Database ----
# Paste your MongoDB Atlas connection string between the quotes.
# Get it from Atlas: Database > Connect > Drivers. Replace <password> with your DB user's password.
MONGODB_URI="mongodb+srv://USER:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"

# ---- Login sessions ----
# A long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="paste-a-long-random-string-here"

# ---- User passwords (you choose these) ----
# The three people who can sign in. Pick a password for each.
FROY_PASSWORD="choose-a-password"
MIGUEL_PASSWORD="choose-a-password"
GIL_PASSWORD="choose-a-password"

# Optional: change the port the app runs on (default 3000)
# PORT=3000
